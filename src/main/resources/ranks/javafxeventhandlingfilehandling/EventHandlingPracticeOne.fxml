<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="692.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ranks.javafxeventhandlingfilehandling.EventHandlingPracticeOne">
   <children>
      <TextField fx:id="txtName" layoutX="199.0" layoutY="47.0" prefHeight="52.0" prefWidth="219.0" />
      <Button fx:id="btnGreet" layoutX="283.0" layoutY="163.0" mnemonicParsing="false" onAction="#handleGreet" text="Greet" />
      <Label fx:id="lblMessage" layoutX="224.0" layoutY="234.0" prefHeight="26.0" prefWidth="150.0" style="-fx-alignment: center;">
         <font>
            <Font name="Arial Black" size="21.0" />
         </font>
      </Label>
      <CheckBox fx:id="chkMusic" layoutX="37.0" layoutY="276.0" mnemonicParsing="false" text="Music" />
      <CheckBox fx:id="chkChess" layoutX="199.0" layoutY="276.0" mnemonicParsing="false" text="Chess" />
      <CheckBox fx:id="chkBoxing" layoutX="337.0" layoutY="276.0" mnemonicParsing="false" text="Boxing" />
      <CheckBox fx:id="chkGaming" layoutX="489.0" layoutY="276.0" mnemonicParsing="false" text="Gaming" />
      <Label fx:id="lblResult" layoutX="19.0" layoutY="344.0" prefHeight="39.0" prefWidth="571.0" style="-fx-alignment: center;">
         <font>
            <Font name="Arial Black" size="26.0" />
         </font>
      </Label>
      <Button fx:id="btnShow" layoutX="262.0" layoutY="307.0" mnemonicParsing="false" onAction="#showHobbies" text="Show Hobbies" />
      <RadioButton fx:id="rbJuice" layoutX="253.0" layoutY="383.0" mnemonicParsing="false" text="Juice">
         <toggleGroup>
            <ToggleGroup fx:id="Refreshments" />
         </toggleGroup>
      </RadioButton>
      <RadioButton fx:id="rbMilk" layoutX="254.0" layoutY="421.0" mnemonicParsing="false" text="Milk" toggleGroup="$Refreshments" />
      <RadioButton fx:id="rbWater" layoutX="254.0" layoutY="457.0" mnemonicParsing="false" text="Water" toggleGroup="$Refreshments" />
      <Button fx:id="btnOutput" layoutX="257.0" layoutY="487.0" mnemonicParsing="false" onAction="#showRefreshments" text="Refreshments" />
      <Label fx:id="lblOutput" layoutX="357.0" layoutY="491.0" prefHeight="18.0" prefWidth="219.0" />
      <ComboBox fx:id="cbLocation" layoutX="226.0" layoutY="546.0" prefWidth="150.0" promptText="Location" />
      <Button fx:id="btnLocation" layoutX="252.0" layoutY="590.0" mnemonicParsing="false" onAction="#showLocation" text="Show Location" />
      <Label fx:id="lblLocation" layoutX="42.0" layoutY="640.0" prefHeight="39.0" prefWidth="543.0" style="-fx-alignment: center;">
         <font>
            <Font name="Arial Black" size="16.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
